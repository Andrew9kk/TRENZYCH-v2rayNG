name: Debug APK on: 
  workflow_dispatch:
jobs: build: runs-on: 
    ubuntu-latest steps:
      - name: Checkout uses: 
        actions/checkout@v4
      - name: Set up Java 
        uses: 
        actions/setup-java@v4 
        with:
          distribution: 
          temurin 
          java-version: '21'
      - name: Set up Android 
      - name: Upload Debug 
      APK SDK
        uses: 
        actions/upload-artifact@v4 
        uses: 
        android-actions/setup-android@v3 
        with: - name: Build 
        Debug APK run: |
          name: debug-apk cd 
          V2rayNG echo 
          "sdk.dir=$ANDROID_HOME"
          path: V2rayNG/app/build/outputs/apk/debug/*.apk          > local.properties
          chmod +x gradlew
          ./gradlew assembleDebug
